sequenceDiagram
    actor User as User
    participant React as React App<br/>(Browser / PWA)
    participant Auth as Firebase<br/>Authentication
    participant DB as Cloud<br/>Firestore
    participant Maps as Google Maps<br/>JavaScript API
    participant Wiki as Wikipedia<br/>API

    %% Authentication Flow
    rect rgb(208, 232, 255)
        Note over User, Auth: Authentication Flow (useAuth Hook)
        User ->> React: Login Action
        React ->> Auth: signInWithEmailAndPassword()
        Auth -->> React: UserCredential (uid, token)
        React -->> User: React Router → Navigate to Home
    end

    %% Station Master Data Load
    rect rgb(212, 245, 233)
        Note over React, Maps: Map & Station Data Load (useStations Hook)
        React ->> DB: getDocs("stations", lineId)<br/>※ EkiData Master (10,447 stations)
        DB -->> React: Station List (station_cd, lat, lon, name)
        React ->> Maps: loadMap() + addMarkers(stations)
        Maps -->> User: Station Markers Displayed
    end

    %% Visit Logging Flow
    rect rgb(255, 234, 167)
        Note over User, DB: Station Visit Logging (useVisits Hook)
        User ->> React: Click Station Marker
        React -->> User: Show Visit Form
        User ->> React: Enter Note & Submit
        React ->> DB: addDoc("visits",<br/>{uid, station_cd, timestamp, note})
        DB -->> React: visit_id returned
        React ->> DB: updateDoc("lines/{line_cd}",<br/>{completion_rate})
        DB -->> React: Update Complete
        React -->> User: Completion Badge Updated
    end

    %% Train Model Logging Flow
    rect rgb(248, 215, 240)
        Note over React, Wiki: Train Model Logging (useTrainModels Hook)
        User ->> React: Search Train Model
        React ->> DB: getDoc("train_models", modelId)
        alt Cache exists
            DB -->> React: Return cached data
        else No cache
            React ->> Wiki: Fetch from Wikipedia API (Free / No Registration)
            Wiki -->> React: Train Model Info
            React ->> DB: setDoc("train_models",<br/>{name, description, cached_at})
        end
        React -->> User: Display Train Model Info
        User ->> React: Enter Sighting Date & Location, Submit
        React ->> DB: addDoc("train_sightings",<br/>{uid, station_cd, model_id, timestamp})
        DB -->> React: sighting_id returned
    end

    %% Social Feed (Real-time Monitoring)
    rect rgb(253, 203, 110)
        Note over React, DB: Social Feed (useFeed Hook)
        React ->> DB: onSnapshot("social_posts", friendIds)
        Note over React, DB: Auto-notified whenever a friend posts (no page reload needed)
        DB -->> React: Post data delivered in real-time
        React -->> User: Feed auto-updated
    end
